<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
  
  
  <mapper namespace="com.karina.app.board.qna.QnaMapper">
  <sql id="search">
  WHERE
  <choose>
  <when test="kind=='v2'">CONTENTS</when>
  <when test="kind=='v3'">WRITER</when>
  <otherwise>TITLE</otherwise>
  </choose>
  
  LIKE '%'||#{search}||'%' <!-- 반복적으로 사용하는 쿼리는 저장해놨다가 include로 꺼내서사용 -->
  </sql>
 <select id="getCount" resultType="Long" parameterType="Pager">
	 SELECT COUNT(NOTICE_NO) FROM TB_QNA
	 <include refid="search"></include>
 </select>
 
  <select id="list" resultType="QnaDTO" parameterType="Pager">
  
 	SELECT * FROM
		(SELECT ROWNUM R,T.* FROM
			(SELECT * FROM TB_QNA 
		 <include refid="search"></include>
			ORDER BY NOTICE_NO DESC) T
		) 
	WHERE R BETWEEN #{first} AND #{last}
  
  </select>
  
  </mapper>