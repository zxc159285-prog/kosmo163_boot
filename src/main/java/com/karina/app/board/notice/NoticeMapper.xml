<?xml version="1.0" encoding="UTF-8"?>

<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
  
  <!-- 네임스페이스에 얘를 사용할 클래스명을 풀패키지명으로 작성한다 FQDN(정규화된 도메인이름) -->
  <mapper namespace="com.karina.app.board.notice.NoticeMapper">
 <!--  리스트 -->
  <select id="list" resultType="NoticeDTO">
  <![CDATA[
  SELECT NOTICE_NO,TITLE,WRITER,CREATEDATE,HIT FROM TB_NOTICE 
  WHERE NOTICE_NO >(SELECT MAX(NOTICE_NO)-10 FROM TB_NOTICE) 
  AND NOTICE_NO <= (SELECT MAX(NOTICE_NO)FROM TB_NOTICE) 
  ORDER BY NOTICE_NO DESC
  ]]>
  </select>
  <!-- 디테일 -->
  <select id="detail" parameterType="NoticeDTO" resultType="NoticeDTO">
  
  </select>
  <!-- 크리에이트 -->
  <insert id="create" parameterType="NoticeDTO">
  INSERT INTO TB_NOTICE
  VALUES (NOTICE_NO_SEQ.NEXTVAL,#{title},#{contents},#{writer},sysdate,0)
  </insert>
  
  </mapper>