<?xml version="1.0" encoding="UTF-8"?>

<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
  
  <!-- 네임스페이스에 얘를 사용할 클래스명을 풀패키지명으로 작성한다 FQDN(정규화된 도메인이름) -->
  <mapper namespace="com.karina.app.departments.DepartmentDAO">
  <!-- 쿼리태그 id에 통상적으로 DAO에서 사용할 메서드명을 적는다 -->
  <!-- 컬럼명과 resultType의 Bean의 Setter이름이 같은걸 찾아서 대입 -->
  <select id="list" resultType="com.karina.app.departments.DepartmentDTO">
  SELECT * FROM TB_DEPARTMENT
  </select>
  
  <select id="detail" parameterType="java.lang.String" resultType="com.karina.app.departments.DepartmentDTO">
  SELECT * FROM TB_DEPARTMENT WHERE DEPARTMENT_NO =#{num}
  </select>
  
  </mapper>